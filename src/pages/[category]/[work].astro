---
import Layout from "../../layouts/Layout.astro";
import { CATEGORIES } from "../../config/site";
import { CONTENTS } from "../../data/contents";

export function getStaticPaths() {
  return CONTENTS
    .filter((item) => item.visible)
    .map((item) => {
      const category = CATEGORIES.find(
        (category) => category.id === item.categoryId
      );

      return {
        params: {
          category: category?.slug,
          work: item.id,
        },
        props: {
          item,
        },
      };
    });
}

const { item } = Astro.props;
---

<Layout title={`${item.title} | Musée de l'Instant`} showHeader={true}>
  <main class="work-page">
    {item.image && <img src={item.image} alt={item.title} />}

    {(item.title || item.body) && (
      <div class="work-caption">
        {item.title && (
          <p class="work-title">
            {item.title}
          </p>
        )}

        {item.body && (
          <p class="work-body">
            {item.body}
          </p>
        )}
      </div>
    )}
  </main>
</Layout>

<style>
.work-page{
  min-height:100vh;
  padding:120px 24px;
  display:grid;
  place-items:center;
  background:#fff;
}

.work-page img{
  display:block;
  width:min(100%,900px);
  height:auto;
}

.work-caption{
  margin:24px 0 0;
  width:min(100%,900px);
  text-align:right;
}

.work-title,
.work-body{
  margin:0;
  font-family:var(--site-font-family);
  letter-spacing:.08em;
  line-height:1.8;
  white-space:pre-line;
}

.work-title{
  color:var(--gallery-detail-title-color);
  font-size:var(--gallery-detail-title-size);
}

.work-body{
  margin-top:4px;
  color:var(--gallery-detail-caption-color);
  font-size:var(--gallery-detail-caption-size);
}
</style>