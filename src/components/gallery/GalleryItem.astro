---
import { THEME } from "../../config/theme";

const {
  image = "",
  title = "",
  body = "",
  href = "",
} = Astro.props;

const hasImage = image !== "";
const hasTitle = title !== "";
const hasBody = body !== "";
---

{href ? (
  <a class="gallery-item" href={href}>
    {hasImage && (
      <img src={image} alt={title} loading="lazy" />
    )}

    {(hasTitle || hasBody) && (
      <div class="gallery-caption">
        {hasTitle && (
          <p
            class="gallery-title"
            style={`font-size:${THEME.typography.galleryTitleSize};font-family:${THEME.typography.fontFamily};`}
          >
            {title}
          </p>
        )}

        {hasBody && (
          <p
            class="gallery-body"
            style={`font-size:${THEME.typography.galleryBodySize};font-family:${THEME.typography.fontFamily};`}
          >
            {body}
          </p>
        )}
      </div>
    )}
  </a>
) : (
  <article class="gallery-item">
    {hasImage && (
      <img src={image} alt={title} loading="lazy" />
    )}

    {(hasTitle || hasBody) && (
      <div class="gallery-caption">
        {hasTitle && (
          <p
            class="gallery-title"
            style={`font-size:${THEME.typography.galleryTitleSize};font-family:${THEME.typography.fontFamily};`}
          >
            {title}
          </p>
        )}

        {hasBody && (
          <p
            class="gallery-body"
            style={`font-size:${THEME.typography.galleryBodySize};font-family:${THEME.typography.fontFamily};`}
          >
            {body}
          </p>
        )}
      </div>
    )}
  </article>
)}

<style>
.gallery-item{
  display:block;
  color:#111;
  text-decoration:none;
}

.gallery-item img{
  display:block;
  width:100%;
  height:auto;
}

.gallery-caption{
  margin-top:14px;
  text-align:right;
  color:#555;
}

.gallery-title,
.gallery-body{
  margin:0;
  letter-spacing:.08em;
  line-height:1.8;
  white-space:pre-line;
}

.gallery-body{
  margin-top:4px;
}
</style>