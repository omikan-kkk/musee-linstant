---
import { THEME } from "../../config/theme";

const {
  image = "",
  title = "",
  body = "",
  href = "",
} = Astro.props;

const hasImage = image !== "";
const hasTitle = title !== "";
const hasBody = body !== "";
---

{href ? (
  <a class="gallery-item" href={href}>
    <div
      class="artwork-frame"
      style={`aspect-ratio:${THEME.gallery.artworkAspectRatio};`}
    >
      <div class="image-area">
        {hasImage && (
          <img
            src={image}
            alt={title}
            loading="lazy"
            style={`max-width:${THEME.gallery.artworkMaxSize};max-height:${THEME.gallery.artworkMaxSize};`}
          />
        )}
      </div>
    </div>

    {(hasTitle || hasBody) && (
      <div
        class="gallery-caption"
        style={`margin-top:${THEME.gallery.captionMarginTop};`}
      >
        {hasTitle && (
          <p
            class="gallery-title"
            style={`font-size:${THEME.typography.galleryTitleSize};font-family:${THEME.typography.fontFamily};`}
          >
            {title}
          </p>
        )}

        {hasBody && (
          <p
            class="gallery-body"
            style={`font-size:${THEME.typography.galleryBodySize};font-family:${THEME.typography.fontFamily};`}
          >
            {body}
          </p>
        )}
      </div>
    )}
  </a>
) : (
  <article class="gallery-item">
    <div
      class="artwork-frame"
      style={`aspect-ratio:${THEME.gallery.artworkAspectRatio};`}
    >
      <div class="image-area">
        {hasImage && (
          <img
            src={image}
            alt={title}
            loading="lazy"
            style={`max-width:${THEME.gallery.artworkMaxSize};max-height:${THEME.gallery.artworkMaxSize};`}
          />
        )}
      </div>
    </div>

    {(hasTitle || hasBody) && (
      <div
        class="gallery-caption"
        style={`margin-top:${THEME.gallery.captionMarginTop};`}
      >
        {hasTitle && (
          <p
            class="gallery-title"
            style={`font-size:${THEME.typography.galleryTitleSize};font-family:${THEME.typography.fontFamily};`}
          >
            {title}
          </p>
        )}

        {hasBody && (
          <p
            class="gallery-body"
            style={`font-size:${THEME.typography.galleryBodySize};font-family:${THEME.typography.fontFamily};`}
          >
            {body}
          </p>
        )}
      </div>
    )}
  </article>
)}

<style>
.gallery-item{
  display:block;
  color:#111;
  text-decoration:none;
}

.artwork-frame{
  width:100%;
  display:grid;
  place-items:center;
}

.image-area{
  width:100%;
  height:100%;
  display:flex;
  align-items:center;
  justify-content:center;
}

.image-area img{
  display:block;
  width:auto;
  height:auto;
  object-fit:contain;
}

.gallery-caption{
  text-align:right;
  color:#555;
}

.gallery-title,
.gallery-body{
  margin:0;
  letter-spacing:.08em;
  line-height:1.8;
  white-space:pre-line;
}

.gallery-body{
  margin-top:4px;
}
</style>