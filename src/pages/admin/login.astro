---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Login | Musée de l'Instant CMS" showHeader={false}>
  <main class="login-page">
    <section class="login-box">
      <h1>Musée de l'Instant CMS</h1>

      <div class="field">
        <label for="password">Password</label>
        <input id="password" type="password" />
      </div>

      <div class="actions">
        <button type="button" id="login-button">Login</button>
        <p id="login-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script type="module">
    import { login } from "../../lib/auth";

    const passwordInput = document.querySelector("#password");
    const loginButton = document.querySelector("#login-button");
    const loginStatus = document.querySelector("#login-status");

    loginButton?.addEventListener("click", async () => {
      if (!passwordInput || !loginStatus) return;

      loginStatus.textContent = "Logging in...";

      try {
        await login(passwordInput.value);
        window.location.href = "/admin";
      } catch (error) {
        console.error(error);
        loginStatus.textContent = "Login failed";
      }
    });
  </script>
</Layout>

<style>
.login-page{
  min-height:100vh;
  display:grid;
  place-items:center;
  padding:24px;
  background:#fff;
  color:#111;
}

.login-box{
  width:min(100%,420px);
  display:flex;
  flex-direction:column;
  gap:32px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

input{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
}

button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

#login-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>