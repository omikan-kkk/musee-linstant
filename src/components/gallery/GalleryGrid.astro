---
const {
  items = [],
} = Astro.props;
---

{items.length > 0 && (
  <section class="gallery-grid">
    <slot />
  </section>
)}

<style>
  .gallery-grid {
    width: min(100%, 1200px);
    margin: 0 auto;
    padding: 120px 24px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 90px 40px;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 110px 48px;
      padding: 140px 32px;
    }
  }
</style>