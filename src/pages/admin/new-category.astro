---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="New Category | Musée de l'Instant CMS" showHeader={false}>
  <main class="admin">
    <header>
      <a href="/admin">← Categories</a>
      <h1>New Category</h1>
    </header>

    <section class="editor">
      <div class="field">
        <label for="title">Title</label>
        <input id="title" type="text" />
      </div>

      <div class="actions">
        <button type="button" id="save-button" class="save-button">Save</button>
        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
  color:#111;
}

header{
  margin-bottom:56px;
}

header a{
  display:inline-block;
  margin-bottom:24px;
  color:#777;
  text-decoration:none;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.editor{
  display:flex;
  flex-direction:column;
  gap:32px;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

input{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
  line-height:1.8;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
}

.save-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>