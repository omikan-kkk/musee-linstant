<button class="menu-button" type="button" aria-label="Open menu">
  <span></span>
  <span></span>
  <span></span>
</button>

<style>
  .menu-button {
    position: fixed;
    top: 28px;
    right: 32px;
    z-index: 20;
    width: 32px;
    height: 32px;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 900ms ease;
  }

  :global(body.has-scrolled) .menu-button {
    opacity: 1;
    pointer-events: auto;
  }

  .menu-button span {
    display: block;
    width: 24px;
    height: 1px;
    margin: 6px auto;
    background: #111;
    transition:
      transform 500ms ease,
      opacity 500ms ease;
  }

  .menu-button.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-button.is-open span:nth-child(2) {
    opacity: 0;
  }

  .menu-button.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>