---
import Layout from "../../../layouts/Layout.astro";
import { CATEGORIES } from "../../../config/site";
import { CONTENTS } from "../../../data/contents";

export function getStaticPaths() {
  return CONTENTS.map((content) => {
    const category = CATEGORIES.find(
      (category) => category.id === content.categoryId
    );

    return {
      params: {
        category: category?.slug,
        content: content.id,
      },
      props: {
        content,
        category,
      },
    };
  });
}

const { content, category } = Astro.props;
---

<Layout title={`${content.title} | Musée de l'Instant CMS`} showHeader={false}>
  <main class="admin">
    <header>
      <a href={`/admin/${category.slug}`}>← {category.title}</a>
      <h1>Edit Content</h1>
    </header>

    <section class="editor" data-content-id={content.id}>
      <div class="field">
        <label for="title">Title</label>
        <input id="title" type="text" value={content.title} />
      </div>

      <div class="field">
        <label for="body">Body</label>
        <textarea id="body" rows="8">{content.body}</textarea>
      </div>

      <div class="field">
        <label for="image">Image</label>
        {content.image && <img id="image-preview" src={content.image} alt={content.title} />}
        <input id="image" type="file" accept="image/*" />
      </div>

      <div class="actions">
        <button type="button" id="save-button" class="save-button">Save</button>
        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script>
    const API_URL = "https://musee-cms-api.azamisound.workers.dev";

    const editor = document.querySelector(".editor");
    const contentId = editor?.getAttribute("data-content-id");

    const titleInput = document.querySelector("#title");
    const bodyInput = document.querySelector("#body");
    const imageInput = document.querySelector("#image");
    const imagePreview = document.querySelector("#image-preview");
    const saveButton = document.querySelector("#save-button");
    const saveStatus = document.querySelector("#save-status");

    imageInput?.addEventListener("change", () => {
      const file = imageInput.files?.[0];

      if (!file || !imagePreview) return;

      const reader = new FileReader();

      reader.addEventListener("load", () => {
        if (typeof reader.result === "string") {
          imagePreview.src = reader.result;
        }
      });

      reader.readAsDataURL(file);
    });

    saveButton?.addEventListener("click", async () => {
      if (!contentId || !titleInput || !bodyInput || !saveStatus) return;

      saveStatus.textContent = "Saving...";

      try {
        const currentRes = await fetch(`${API_URL}/contents`);
        const currentData = await currentRes.json();

        if (!currentData.ok) {
          throw new Error("Could not load contents.");
        }

        const nextContents = currentData.contents.map((content) => {
          if (content.id !== contentId) return content;

          return {
            ...content,
            title: titleInput.value,
            body: bodyInput.value,
          };
        });

        const saveRes = await fetch(`${API_URL}/contents`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            contents: nextContents,
          }),
        });

        const saveData = await saveRes.json();

        if (!saveData.ok) {
          throw new Error("Could not save contents.");
        }

        saveStatus.textContent = "Saved to GitHub";
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Save failed";
      }
    });
  </script>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
  color:#111;
}

header{
  margin-bottom:56px;
}

header a{
  display:inline-block;
  margin-bottom:24px;
  color:#777;
  text-decoration:none;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.editor{
  display:flex;
  flex-direction:column;
  gap:32px;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

input,
textarea{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
  line-height:1.8;
}

input[type="file"]{
  border:none;
  padding:0;
  font-size:12px;
}

textarea{
  resize:vertical;
}

img{
  display:block;
  width:min(100%,420px);
  height:auto;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
}

.save-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>