---
const {
  image = "",
  caption = "",
  href = "",
} = Astro.props;

const hasImage = image !== "";
const hasCaption = caption !== "";
const tag = href ? "a" : "article";
---

<Fragment set:html={`<${tag} class="gallery-item"${href ? ` href="${href}"` : ""}>`} />

  {hasImage && (
    <img src={image} alt={caption} loading="lazy" />
  )}

  {hasCaption && (
    <p>{caption}</p>
  )}

<Fragment set:html={`</${tag}>`} />

<style>
  .gallery-item {
    display: block;
    text-decoration: none;
    color: #111;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  .gallery-item p {
  margin-top: 14px;

  text-align: right;

  font-size: 10px;

  letter-spacing: 0.08em;

  line-height: 1.8;

  color: #555;
}
</style>