---
import Layout from "../layouts/Layout.astro";
import GalleryCategory from "../components/category/GalleryCategory.astro";
import BookCategory from "../components/category/BookCategory.astro";
import { CATEGORIES } from "../config/site";
import { CONTENTS } from "../data/contents";

export function getStaticPaths() {
  return CATEGORIES
    .filter((category) => category.visible)
    .map((category) => ({
      params: { slug: category.slug },
      props: { category },
    }));
}

const { category } = Astro.props;

const items = CONTENTS
  .filter((item) => item.categoryId === category.id)
  .filter((item) => item.visible)
  .sort((a, b) => a.order - b.order);

const categoryType = category.type || "gallery";
---

<Layout
  title={`${category.title} | Musée de l'Instant`}
  showHeader={true}
  showEdgeFade={true}
>
  {(categoryType === "gallery" || categoryType === "coffee") && (
    <GalleryCategory category={category} items={items} />
  )}

  {categoryType === "book" && (
    <BookCategory items={items} />
  )}

  {categoryType === "music" && (
    <GalleryCategory category={category} items={items} />
  )}
</Layout>