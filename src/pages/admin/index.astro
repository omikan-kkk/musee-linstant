---
import Layout from "../../layouts/Layout.astro";
import { CATEGORIES } from "../../config/site";

const categories = CATEGORIES
  .sort((a, b) => a.order - b.order);
---

<Layout title="Musée de l'Instant CMS" showHeader={false}>
  <main class="admin">
    <header class="admin-header">
      <h1>Musée de l'Instant CMS</h1>

      <button type="button" id="logout-button" class="logout-button">
        Logout
      </button>
    </header>

    <section class="admin-section">
      <div class="section-heading">
        <p>Category</p>

        <a class="add-category" href="/admin/new-category">
          ＋ Add Category
        </a>
      </div>

      <nav class="category-list" id="category-list">
        {categories.map((category) => (
          <div
            class="category-row"
            draggable="true"
            data-category-id={category.id}
          >
            <span class="drag-handle">☰</span>

            <a class="category-title" href={`/admin/${category.slug}`}>
              {category.title}
              {!category.visible && <span class="hidden-label">Hidden</span>}
            </a>

            <a class="edit-link" href={`/admin/category/${category.id}`}>
              Edit
            </a>
          </div>
        ))}
      </nav>

      <div class="actions">
        <button type="button" id="save-order-button" class="save-order-button">
          Save Order
        </button>

        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script type="module">
    import { requireLogin, logout, authFetch } from "../../lib/auth";

    requireLogin();

    const list = document.querySelector("#category-list");
    const saveButton = document.querySelector("#save-order-button");
    const saveStatus = document.querySelector("#save-status");
    const logoutButton = document.querySelector("#logout-button");

    logoutButton?.addEventListener("click", () => {
      logout();
    });

    let draggedRow = null;

    list?.addEventListener("dragstart", (event) => {
      const row = event.target.closest(".category-row");
      if (!row) return;

      draggedRow = row;
      row.classList.add("is-dragging");
    });

    list?.addEventListener("dragend", () => {
      if (draggedRow) {
        draggedRow.classList.remove("is-dragging");
      }

      draggedRow = null;
    });

    list?.addEventListener("dragover", (event) => {
      event.preventDefault();

      const dragging = document.querySelector(".is-dragging");
      const rows = [...list.querySelectorAll(".category-row:not(.is-dragging)")];

      const nextRow = rows.find((row) => {
        const box = row.getBoundingClientRect();
        return event.clientY < box.top + box.height / 2;
      });

      if (!dragging) return;

      if (nextRow) {
        list.insertBefore(dragging, nextRow);
      } else {
        list.appendChild(dragging);
      }
    });

    saveButton?.addEventListener("click", async () => {
      if (!list || !saveStatus) return;

      saveStatus.textContent = "Saving...";

      const orderedIds = [...list.querySelectorAll(".category-row")]
        .map((row) => row.getAttribute("data-category-id"))
        .filter(Boolean);

      try {
        const currentRes = await authFetch("/categories");
        const currentData = await currentRes.json();

        if (!currentData.ok) {
          throw new Error("Could not load categories.");
        }

        const nextCategories = currentData.categories.map((category) => {
          const index = orderedIds.indexOf(category.id);

          if (index === -1) return category;

          return {
            ...category,
            order: index + 1,
          };
        });

        const saveRes = await authFetch("/categories", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            categories: nextCategories,
          }),
        });

        const saveData = await saveRes.json();

        if (!saveData.ok) {
          throw new Error("Could not save order.");
        }

        saveStatus.textContent = "Order saved";
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Save failed";
      }
    });
  </script>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  background:#fff;
  color:#111;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
}

.admin-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:24px;
  margin-bottom:64px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
  letter-spacing:.04em;
}

.logout-button{
  border:none;
  background:transparent;
  color:#777;
  font-size:12px;
  letter-spacing:.08em;
  cursor:pointer;
  padding:0;
}

.admin-section{
  display:flex;
  flex-direction:column;
  gap:28px;
}

.section-heading{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:24px;
}

.section-heading p{
  margin:0;
  font-size:12px;
  letter-spacing:.12em;
  color:#777;
}

.add-category{
  color:#111;
  text-decoration:none;
  font-size:12px;
  letter-spacing:.08em;
}

.category-list{
  display:flex;
  flex-direction:column;
  gap:22px;
}

.category-row{
  display:grid;
  grid-template-columns:auto 1fr auto;
  align-items:center;
  gap:14px;
  cursor:grab;
}

.category-row.is-dragging{
  opacity:.35;
}

.drag-handle{
  color:#999;
  font-size:14px;
  user-select:none;
}

.category-title{
  color:#111;
  text-decoration:none;
  font-size:18px;
  letter-spacing:.08em;
}

.edit-link{
  color:#777;
  text-decoration:none;
  font-size:12px;
  letter-spacing:.08em;
}

.hidden-label{
  margin-left:10px;
  color:#999;
  font-size:11px;
  letter-spacing:.08em;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
}

.save-order-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>