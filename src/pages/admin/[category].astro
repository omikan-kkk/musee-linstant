---
import Layout from "../../layouts/Layout.astro";
import { CATEGORIES } from "../../config/site";
import { CONTENTS } from "../../data/contents";

export function getStaticPaths() {
  return CATEGORIES
    .filter(category => category.visible)
    .map(category => ({
      params: {
        category: category.slug,
      },
      props: {
        category,
      },
    }));
}

const { category } = Astro.props;

const contents = CONTENTS.filter(
  content => content.categoryId === category.id
);
---

<Layout title={`${category.title} | Musée de l'Instant CMS`} showHeader={false}>
  <main class="admin">

    <header>
      <a href="/admin">← Categories</a>

      <h1>{category.title}</h1>

      <a class="add-button" href={`/admin/${category.slug}/new`}>
        ＋ Add Content
      </a>
    </header>

    <section class="content-list">

      {contents.map(content => (
        <a href={`/admin/${category.slug}/${content.id}`}>
          {content.title}
        </a>
      ))}

    </section>

  </main>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
}

header{
  display:flex;
  flex-direction:column;
  gap:20px;
  margin-bottom:48px;
}

header a{
  text-decoration:none;
  color:#777;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.add-button{
  align-self:flex-start;
  color:#111;
}

.content-list{
  display:flex;
  flex-direction:column;
  gap:22px;
}

.content-list a{
  color:#111;
  text-decoration:none;
  font-size:18px;
}
</style>