---
import Layout from "../../../layouts/Layout.astro";
import { CATEGORIES } from "../../../config/site";

export function getStaticPaths() {
  return CATEGORIES
    .filter((category) => category.visible)
    .map((category) => ({
      params: {
        category: category.slug,
      },
      props: {
        category,
      },
    }));
}

const { category } = Astro.props;
const categoryType = category.type || "gallery";
const isBook = categoryType === "book";
const isCoffee = categoryType === "coffee";
const isGalleryLike = !isBook && !isCoffee;
---

<Layout title="New Content | Musée de l'Instant CMS" showHeader={false}>
  <main class="admin">
    <header>
      <a href={`/admin/${category.slug}`}>← {category.title}</a>
      <h1>New Content</h1>
    </header>

    <section
      class="editor"
      data-category-id={category.id}
      data-category-slug={category.slug}
      data-category-type={categoryType}
    >
      {isBook && (
        <>
          <div class="field">
            <label for="author">Author</label>
            <input id="author" type="text" />
          </div>

          <div class="field">
            <label for="author-sort">Author Sort</label>
            <input id="author-sort" type="text" />
          </div>

          <div class="override-group">
            <div class="field checkbox-field">
              <input
                id="author-font-size-override"
                type="checkbox"
              />

              <label for="author-font-size-override">
                Override Font Size
              </label>
            </div>

            <div class="field">
              <label for="author-font-size">
                Author Font Size
              </label>

              <div class="number-field">
                <input
                  id="author-font-size"
                  type="number"
                  min="1"
                  step="1"
                  value="13"
                  disabled
                />

                <span>px</span>
              </div>
            </div>
          </div>

          <div class="field">
            <label for="title">Work Title</label>
            <input id="title" type="text" />
          </div>

          <div class="field">
            <label for="title-sort">Title Sort</label>
            <input id="title-sort" type="text" />
          </div>

          <div class="override-group">
            <div class="field checkbox-field">
              <input
                id="title-font-size-override"
                type="checkbox"
              />

              <label for="title-font-size-override">
                Override Font Size
              </label>
            </div>

            <div class="field">
              <label for="title-font-size">
                Title Font Size
              </label>

              <div class="number-field">
                <input
                  id="title-font-size"
                  type="number"
                  min="1"
                  step="1"
                  value="13"
                  disabled
                />

                <span>px</span>
              </div>
            </div>
          </div>
        </>
      )}

      {isCoffee && (
        <>
          <div class="field">
            <label for="coffee-date">Date</label>
            <input id="coffee-date" type="date" />

            <p class="note">
              Saved as YYYY-MM-DD and displayed as YYYY/MM/DD.
            </p>
          </div>

          <div class="field">
            <label for="coffee-brand">Brand</label>
            <input id="coffee-brand" type="text" />
          </div>

          <div class="field">
            <label for="coffee-name">Name</label>
            <input id="coffee-name" type="text" />
          </div>

          <div class="field">
            <label for="coffee-notes">Notes</label>
            <input id="coffee-notes" type="text" />
          </div>
        </>
      )}

      {isGalleryLike && (
        <>
          <div class="field">
            <label for="title">Title</label>
            <input id="title" type="text" />
          </div>

          <div class="field">
            <label for="body">Body</label>
            <textarea id="body" rows="8"></textarea>
          </div>

          <div class="field">
            <label for="image">Image</label>

            <img
              id="image-preview"
              class="is-hidden"
              alt=""
            />

            <input
              id="image"
              type="file"
              accept="image/*"
            />
          </div>
        </>
      )}

      <div class="actions">
        <button type="button" id="save-button" class="save-button">
          Save
        </button>

        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script type="module">
    import { requireLogin, authFetch } from "../../../lib/auth";

    requireLogin();

    const editor = document.querySelector(".editor");
    const categoryId = editor?.getAttribute("data-category-id");
    const categorySlug = editor?.getAttribute("data-category-slug");
    const categoryType =
      editor?.getAttribute("data-category-type") || "gallery";

    const authorInput = document.querySelector("#author");
    const authorSortInput = document.querySelector("#author-sort");

    const authorFontSizeOverrideInput =
      document.querySelector("#author-font-size-override");

    const authorFontSizeInput =
      document.querySelector("#author-font-size");

    const titleInput = document.querySelector("#title");
    const titleSortInput = document.querySelector("#title-sort");

    const titleFontSizeOverrideInput =
      document.querySelector("#title-font-size-override");

    const titleFontSizeInput =
      document.querySelector("#title-font-size");

    const bodyInput = document.querySelector("#body");

    const coffeeDateInput = document.querySelector("#coffee-date");
    const coffeeBrandInput = document.querySelector("#coffee-brand");
    const coffeeNameInput = document.querySelector("#coffee-name");
    const coffeeNotesInput = document.querySelector("#coffee-notes");

    const imageInput = document.querySelector("#image");
    const imagePreview = document.querySelector("#image-preview");

    const saveButton = document.querySelector("#save-button");
    const saveStatus = document.querySelector("#save-status");

    let selectedImageFile = null;

    function updateOverrideInputState(
      checkboxInput,
      numberInput
    ) {
      if (!checkboxInput || !numberInput) {
        return;
      }

      numberInput.disabled = !checkboxInput.checked;
    }

    authorFontSizeOverrideInput?.addEventListener(
      "change",
      () => {
        updateOverrideInputState(
          authorFontSizeOverrideInput,
          authorFontSizeInput
        );
      }
    );

    titleFontSizeOverrideInput?.addEventListener(
      "change",
      () => {
        updateOverrideInputState(
          titleFontSizeOverrideInput,
          titleFontSizeInput
        );
      }
    );

    function getNextContentId(contents) {
      const maxNumber = contents.reduce((max, content) => {
        const match = content.id?.match(/^content(\d+)$/);

        if (!match) {
          return max;
        }

        const number = Number(match[1]);

        return Number.isFinite(number)
          ? Math.max(max, number)
          : max;
      }, 0);

      return `content${String(maxNumber + 1).padStart(6, "0")}`;
    }

    async function uploadImage(file, contentId) {
      const formData = new FormData();
      formData.append("file", file);
      formData.append("contentId", contentId);

      const uploadRes = await authFetch("/upload-image", {
        method: "POST",
        body: formData,
      });

      const uploadData = await uploadRes.json();

      if (!uploadData.ok) {
        throw new Error("Could not upload image.");
      }

      return uploadData.image;
    }

    imageInput?.addEventListener("change", () => {
      const file = imageInput.files?.[0];

      if (!file || !imagePreview) {
        selectedImageFile = null;
        return;
      }

      selectedImageFile = file;

      const previewUrl = URL.createObjectURL(file);
      imagePreview.src = previewUrl;
      imagePreview.alt = file.name;
      imagePreview.classList.remove("is-hidden");
    });

    saveButton?.addEventListener("click", async () => {
      if (
        !categoryId ||
        !categorySlug ||
        !saveStatus
      ) {
        return;
      }

      const title = titleInput?.value.trim() || "";
      const body = bodyInput?.value || "";

      const author = authorInput?.value.trim() || "";

      const authorSort =
        authorSortInput?.value.trim() || author;

      const titleSort =
        titleSortInput?.value.trim() || title;

      const authorFontSizeOverride =
        authorFontSizeOverrideInput?.checked || false;

      const titleFontSizeOverride =
        titleFontSizeOverrideInput?.checked || false;

      const authorFontSize = Number(
        authorFontSizeInput?.value
      );

      const titleFontSize = Number(
        titleFontSizeInput?.value
      );

      const coffeeDate =
        coffeeDateInput?.value.trim() || "";

      const coffeeBrand =
        coffeeBrandInput?.value.trim() || "";

      const coffeeName =
        coffeeNameInput?.value.trim() || "";

      const coffeeNotes =
        coffeeNotesInput?.value.trim() || "";

      if (categoryType === "book") {
        if (!author) {
          saveStatus.textContent = "Author is required";
          return;
        }

        if (!authorSort) {
          saveStatus.textContent = "Author Sort is required";
          return;
        }

        if (!title) {
          saveStatus.textContent = "Work Title is required";
          return;
        }

        if (!titleSort) {
          saveStatus.textContent = "Title Sort is required";
          return;
        }

        if (
          authorFontSizeOverride &&
          (
            !Number.isFinite(authorFontSize) ||
            authorFontSize <= 0
          )
        ) {
          saveStatus.textContent =
            "Author Font Size must be a positive number.";
          return;
        }

        if (
          titleFontSizeOverride &&
          (
            !Number.isFinite(titleFontSize) ||
            titleFontSize <= 0
          )
        ) {
          saveStatus.textContent =
            "Title Font Size must be a positive number.";
          return;
        }
      } else if (categoryType === "coffee") {
        if (!coffeeDate) {
          saveStatus.textContent = "Date is required";
          return;
        }

        if (!coffeeBrand) {
          saveStatus.textContent = "Brand is required";
          return;
        }

        if (!coffeeName) {
          saveStatus.textContent = "Name is required";
          return;
        }

        if (!coffeeNotes) {
          saveStatus.textContent = "Notes are required";
          return;
        }
      } else {
        if (!title) {
          saveStatus.textContent = "Title is required";
          return;
        }

        if (!selectedImageFile) {
          saveStatus.textContent = "Image is required";
          return;
        }
      }

      saveButton.disabled = true;
      saveStatus.textContent = "Saving...";

      try {
        const currentRes = await authFetch("/contents");
        const currentData = await currentRes.json();

        if (!currentData.ok) {
          throw new Error("Could not load contents.");
        }

        const nextId = getNextContentId(
          currentData.contents
        );

        const sameCategoryContents =
          currentData.contents.filter(
            (content) =>
              content.categoryId === categoryId
          );

        const nextOrder =
          sameCategoryContents.length + 1;

        let uploadedImagePath = "";

        if (
          categoryType !== "book" &&
          categoryType !== "coffee" &&
          selectedImageFile
        ) {
          saveStatus.textContent = "Uploading image...";

          uploadedImagePath = await uploadImage(
            selectedImageFile,
            nextId
          );
        }

        saveStatus.textContent = "Saving content...";

        let newContent;

        if (categoryType === "book") {
          newContent = {
            id: nextId,
            categoryId,
            slug: nextId,
            image: "",
            title,
            body: "",
            author,
            authorSort,
            titleSort,
            authorFontSizeOverride,
            authorFontSize:
              authorFontSizeOverride
                ? authorFontSize
                : null,
            titleFontSizeOverride,
            titleFontSize:
              titleFontSizeOverride
                ? titleFontSize
                : null,
            visible: true,
            order: nextOrder,
          };
        } else if (categoryType === "coffee") {
          newContent = {
            id: nextId,
            categoryId,
            slug: nextId,
            image: "",
            title: "",
            body: "",
            date: coffeeDate,
            brand: coffeeBrand,
            coffeeName,
            notes: coffeeNotes,
            visible: true,
            order: nextOrder,
          };
        } else {
          newContent = {
            id: nextId,
            categoryId,
            slug: nextId,
            image: uploadedImagePath,
            title,
            body,
            visible: true,
            order: nextOrder,
          };
        }

        const nextContents = [
          ...currentData.contents,
          newContent,
        ];

        const saveRes = await authFetch("/contents", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            contents: nextContents,
          }),
        });

        const saveData = await saveRes.json();

        if (!saveData.ok) {
          throw new Error(
            "Could not save contents."
          );
        }

        saveStatus.textContent =
          "Saved to GitHub. Redirecting...";

        window.location.href =
          `/admin/${categorySlug}`;
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Save failed";
        saveButton.disabled = false;
      }
    });
  </script>
</Layout>
<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
  color:#111;
}

header{
  margin-bottom:56px;
}

header a{
  display:inline-block;
  margin-bottom:24px;
  color:#777;
  text-decoration:none;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.editor{
  display:flex;
  flex-direction:column;
  gap:32px;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.override-group{
  display:flex;
  flex-direction:column;
  gap:14px;
  padding:16px 0 4px;
}

.checkbox-field{
  flex-direction:row;
  align-items:center;
  gap:10px;
}

.checkbox-field input{
  width:auto;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

.checkbox-field label{
  color:#111;
  letter-spacing:.08em;
}

input,
textarea{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
  line-height:1.8;
}

input:disabled{
  color:#aaa;
  background:#f5f5f5;
  cursor:not-allowed;
}

input[type="checkbox"]{
  width:auto;
}

input[type="file"]{
  border:none;
  padding:0;
  font-size:12px;
}

.number-field{
  display:grid;
  grid-template-columns:minmax(0,1fr) auto;
  align-items:center;
  gap:10px;
}

.number-field span{
  color:#777;
  font-size:12px;
}

textarea{
  resize:vertical;
}

.note{
  margin:0;
  color:#999;
  font-size:11px;
  line-height:1.6;
}

img{
  display:block;
  width:min(100%,420px);
  height:auto;
}

img.is-hidden{
  display:none;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
  flex-wrap:wrap;
}

.save-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

.save-button:disabled{
  opacity:.5;
  cursor:not-allowed;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>