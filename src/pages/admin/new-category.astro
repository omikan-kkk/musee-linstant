---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="New Category | Musée de l'Instant CMS" showHeader={false}>
  <main class="admin">
    <header>
      <a href="/admin">← Categories</a>
      <h1>New Category</h1>
    </header>

    <section class="editor">
      <div class="field">
        <label for="title">Title</label>
        <input id="title" type="text" />
      </div>

      <div class="actions">
        <button type="button" id="save-button" class="save-button">Save</button>
        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script type="module">
    import { requireLogin, authFetch } from "../../lib/auth";

    requireLogin();

    const titleInput = document.querySelector("#title");
    const saveButton = document.querySelector("#save-button");
    const saveStatus = document.querySelector("#save-status");

    function getNextCategoryId(categories) {
      const maxNumber = categories.reduce((max, category) => {
        const match = category.id?.match(/^category(\d+)$/);
        if (!match) return max;

        const number = Number(match[1]);
        return Number.isFinite(number) ? Math.max(max, number) : max;
      }, 0);

      return `category${String(maxNumber + 1).padStart(3, "0")}`;
    }

    function createSlug(title) {
      return title
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "") || "category";
    }

    saveButton?.addEventListener("click", async () => {
      if (!titleInput || !saveStatus) return;

      const title = titleInput.value.trim();

      if (!title) {
        saveStatus.textContent = "Title is required";
        return;
      }

      saveStatus.textContent = "Saving...";

      try {
        const currentRes = await authFetch("/categories");
        const currentData = await currentRes.json();

        if (!currentData.ok) {
          throw new Error("Could not load categories.");
        }

        const nextId = getNextCategoryId(currentData.categories);
        const nextOrder = currentData.categories.length + 1;

        const newCategory = {
          id: nextId,
          title,
          slug: createSlug(title),
          visible: true,
          order: nextOrder,
        };

        const nextCategories = [...currentData.categories, newCategory];

        const saveRes = await authFetch("/categories", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            categories: nextCategories,
          }),
        });

        const saveData = await saveRes.json();

        if (!saveData.ok) {
          throw new Error("Could not save categories.");
        }

        saveStatus.textContent = "Saved to GitHub. Redirecting...";

        window.location.href = "/admin";
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Save failed";
      }
    });
  </script>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
  color:#111;
}

header{
  margin-bottom:56px;
}

header a{
  display:inline-block;
  margin-bottom:24px;
  color:#777;
  text-decoration:none;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.editor{
  display:flex;
  flex-direction:column;
  gap:32px;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

input{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
  line-height:1.8;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
}

.save-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>