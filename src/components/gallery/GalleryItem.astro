---
import { THEME } from "../../config/theme";

const {
  image = "",
  title = "",
  body = "",
  href = "",
} = Astro.props;

const hasImage = image !== "";
const hasTitle = title !== "";
const hasBody = body !== "";
---

{href ? (
  <a class="gallery-item" href={href}>
    <div
      class="artwork-frame"
      style={`--artwork-ratio:${THEME.gallery.artworkAspectRatio};`}
    >
      {hasImage && (
        <img
          src={image}
          alt={title}
          loading="lazy"
          style={`max-width:${THEME.gallery.artworkMaxSize};max-height:${THEME.gallery.artworkMaxSize};`}
        />
      )}
    </div>

    {(hasTitle || hasBody) && (
      <div
        class="gallery-caption"
        style={`margin-top:${THEME.gallery.captionMarginTop};`}
      >
        {hasTitle && (
          <p class="gallery-title">
            {title}
          </p>
        )}

        {hasBody && (
          <p class="gallery-body">
            {body}
          </p>
        )}
      </div>
    )}
  </a>
) : (
  <article class="gallery-item">
    <div
      class="artwork-frame"
      style={`--artwork-ratio:${THEME.gallery.artworkAspectRatio};`}
    >
      {hasImage && (
        <img
          src={image}
          alt={title}
          loading="lazy"
          style={`max-width:${THEME.gallery.artworkMaxSize};max-height:${THEME.gallery.artworkMaxSize};`}
        />
      )}
    </div>

    {(hasTitle || hasBody) && (
      <div
        class="gallery-caption"
        style={`margin-top:${THEME.gallery.captionMarginTop};`}
      >
        {hasTitle && (
          <p class="gallery-title">
            {title}
          </p>
        )}

        {hasBody && (
          <p class="gallery-body">
            {body}
          </p>
        )}
      </div>
    )}
  </article>
)}

<style>
.gallery-item{
  display:block;
  color:inherit;
  text-decoration:none;
}

.artwork-frame{
  position:relative;
  width:100%;
  height:auto;
  overflow:hidden;
}

.artwork-frame::before{
  content:"";
  display:block;
  width:100%;
  aspect-ratio:var(--artwork-ratio);
}

.artwork-frame img{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
  display:block;
  width:auto;
  height:auto;
  object-fit:contain;
}

.gallery-caption{
  text-align:right;
}

.gallery-title,
.gallery-body{
  margin:0;
  font-family:var(--site-font-family);
  letter-spacing:.08em;
  line-height:1.8;
  white-space:pre-line;
}

.gallery-title{
  color:var(--gallery-list-title-color);
  font-size:var(--gallery-list-title-size);
}

.gallery-body{
  margin-top:4px;
  color:var(--gallery-list-caption-color);
  font-size:var(--gallery-list-caption-size);
}
</style>