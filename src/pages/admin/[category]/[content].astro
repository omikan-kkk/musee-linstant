---
import Layout from "../../../layouts/Layout.astro";
import { CATEGORIES } from "../../../config/site";
import { CONTENTS } from "../../../data/contents";

export function getStaticPaths() {
  return CONTENTS
    .map((content) => {
      const category = CATEGORIES.find(
        (category) => category.id === content.categoryId
      );

      return {
        content,
        category,
      };
    })
    .filter(({ category }) => Boolean(category))
    .map(({ content, category }) => ({
      params: {
        category: category.slug,
        content: content.id,
      },
      props: {
        content,
        category,
      },
    }));
}

const { content, category } = Astro.props;

const categoryType = category.type || "gallery";
const isBook = categoryType === "book";
const isCoffee = categoryType === "coffee";
const isGalleryLike = !isBook && !isCoffee;

const displayTitle =
  content.title ||
  content.coffeeName ||
  "Content";
---

<Layout title={`${displayTitle} | Musée de l'Instant CMS`} showHeader={false}>
  <main class="admin">
    <header>
      <a href={`/admin/${category.slug}`}>← {category.title}</a>
      <h1>Edit Content</h1>
    </header>

    <section
      class="editor"
      data-content-id={content.id}
      data-category-slug={category.slug}
      data-category-type={categoryType}
    >
      {isBook && (
        <>
          <div class="field">
            <label for="author">Author</label>
            <input
              id="author"
              type="text"
              value={content.author || ""}
            />
          </div>

          <div class="field">
            <label for="author-sort">Author Sort</label>
            <input
              id="author-sort"
              type="text"
              value={content.authorSort || content.author || ""}
            />
          </div>

          <div class="field">
            <label for="title">Work Title</label>
            <input
              id="title"
              type="text"
              value={content.title || ""}
            />
          </div>

          <div class="field">
            <label for="title-sort">Title Sort</label>
            <input
              id="title-sort"
              type="text"
              value={content.titleSort || content.title || ""}
            />
          </div>
        </>
      )}

      {isCoffee && (
        <>
          <div class="field">
            <label for="coffee-date">Date</label>
            <input
              id="coffee-date"
              type="date"
              value={content.date || ""}
            />
            <p class="note">
              Saved as YYYY-MM-DD and displayed as YYYY/MM/DD.
            </p>
          </div>

          <div class="field">
            <label for="coffee-brand">Brand</label>
            <input
              id="coffee-brand"
              type="text"
              value={content.brand || ""}
            />
          </div>

          <div class="field">
            <label for="coffee-name">Name</label>
            <input
              id="coffee-name"
              type="text"
              value={content.coffeeName || ""}
            />
          </div>

          <div class="field">
            <label for="coffee-notes">Notes</label>
            <input
              id="coffee-notes"
              type="text"
              value={content.notes || ""}
            />
          </div>
        </>
      )}

      {isGalleryLike && (
        <>
          <div class="field">
            <label for="title">Title</label>
            <input
              id="title"
              type="text"
              value={content.title || ""}
            />
          </div>

          <div class="field">
            <label for="body">Body</label>
            <textarea id="body" rows="8">{content.body}</textarea>
          </div>

          <div class="field">
            <label for="image">Image</label>

            {content.image && (
              <img
                id="image-preview"
                src={content.image}
                alt={content.title}
              />
            )}

            {!content.image && (
              <img
                id="image-preview"
                class="is-hidden"
                alt=""
              />
            )}

            <input
              id="image"
              type="file"
              accept="image/*"
            />
          </div>
        </>
      )}

      <div class="field checkbox-field">
        <input
          id="visible"
          type="checkbox"
          checked={content.visible}
        />
        <label for="visible">Visible</label>
      </div>

      <div class="actions">
        <button
          type="button"
          id="save-button"
          class="save-button"
        >
          Save
        </button>

        <button
          type="button"
          id="delete-button"
          class="delete-button"
        >
          Delete Content
        </button>

        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script type="module">
    import { requireLogin, authFetch } from "../../../lib/auth";

    requireLogin();

    const editor = document.querySelector(".editor");
    const contentId = editor?.getAttribute("data-content-id");
    const categorySlug = editor?.getAttribute("data-category-slug");
    const categoryType =
      editor?.getAttribute("data-category-type") || "gallery";

    const authorInput = document.querySelector("#author");
    const authorSortInput = document.querySelector("#author-sort");
    const titleInput = document.querySelector("#title");
    const titleSortInput = document.querySelector("#title-sort");
    const bodyInput = document.querySelector("#body");

    const coffeeDateInput = document.querySelector("#coffee-date");
    const coffeeBrandInput = document.querySelector("#coffee-brand");
    const coffeeNameInput = document.querySelector("#coffee-name");
    const coffeeNotesInput = document.querySelector("#coffee-notes");

    const imageInput = document.querySelector("#image");
    const imagePreview = document.querySelector("#image-preview");
    const visibleInput = document.querySelector("#visible");
    const saveButton = document.querySelector("#save-button");
    const deleteButton = document.querySelector("#delete-button");
    const saveStatus = document.querySelector("#save-status");

    let selectedImageFile = null;

    async function loadContents() {
      const currentRes = await authFetch("/contents");
      const currentData = await currentRes.json();

      if (!currentData.ok) {
        throw new Error("Could not load contents.");
      }

      return currentData.contents;
    }

    async function saveContents(contents) {
      const saveRes = await authFetch("/contents", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          contents,
        }),
      });

      const saveData = await saveRes.json();

      if (!saveData.ok) {
        throw new Error("Could not save contents.");
      }

      return saveData;
    }

    async function uploadImage(file, contentId) {
      const formData = new FormData();
      formData.append("file", file);
      formData.append("contentId", contentId);

      const uploadRes = await authFetch("/upload-image", {
        method: "POST",
        body: formData,
      });

      const uploadData = await uploadRes.json();

      if (!uploadData.ok) {
        throw new Error("Could not upload image.");
      }

      return uploadData.image;
    }

    imageInput?.addEventListener("change", () => {
      const file = imageInput.files?.[0];

      if (!file || !imagePreview) return;

      selectedImageFile = file;

      const previewUrl = URL.createObjectURL(file);
      imagePreview.src = previewUrl;
      imagePreview.classList.remove("is-hidden");
    });

    saveButton?.addEventListener("click", async () => {
      if (
        !contentId ||
        !visibleInput ||
        !saveStatus
      ) {
        return;
      }

      const title = titleInput?.value.trim() || "";
      const body = bodyInput?.value || "";

      const author = authorInput?.value.trim() || "";
      const authorSort =
        authorSortInput?.value.trim() || author;
      const titleSort =
        titleSortInput?.value.trim() || title;

      const coffeeDate =
        coffeeDateInput?.value.trim() || "";
      const coffeeBrand =
        coffeeBrandInput?.value.trim() || "";
      const coffeeName =
        coffeeNameInput?.value.trim() || "";
      const coffeeNotes =
        coffeeNotesInput?.value.trim() || "";

      if (categoryType === "book") {
        if (!author) {
          saveStatus.textContent = "Author is required";
          return;
        }

        if (!authorSort) {
          saveStatus.textContent = "Author Sort is required";
          return;
        }

        if (!title) {
          saveStatus.textContent = "Work Title is required";
          return;
        }

        if (!titleSort) {
          saveStatus.textContent = "Title Sort is required";
          return;
        }
      } else if (categoryType === "coffee") {
        if (!coffeeDate) {
          saveStatus.textContent = "Date is required";
          return;
        }

        if (!coffeeBrand) {
          saveStatus.textContent = "Brand is required";
          return;
        }

        if (!coffeeName) {
          saveStatus.textContent = "Name is required";
          return;
        }

        if (!coffeeNotes) {
          saveStatus.textContent = "Notes are required";
          return;
        }
      } else if (!title) {
        saveStatus.textContent = "Title is required";
        return;
      }

      saveStatus.textContent = "Saving...";

      try {
        const currentContents = await loadContents();

        let nextImagePath = null;

        if (
          categoryType !== "book" &&
          categoryType !== "coffee" &&
          selectedImageFile
        ) {
          saveStatus.textContent = "Uploading image...";

          nextImagePath = await uploadImage(
            selectedImageFile,
            contentId
          );
        }

        saveStatus.textContent = "Saving content...";

        const nextContents = currentContents.map((content) => {
          if (content.id !== contentId) {
            return content;
          }

          if (categoryType === "book") {
            return {
              ...content,
              title,
              body: "",
              image: "",
              author,
              authorSort,
              titleSort,
              visible: visibleInput.checked,
            };
          }

          if (categoryType === "coffee") {
            return {
              ...content,
              title: "",
              body: "",
              image: "",
              date: coffeeDate,
              brand: coffeeBrand,
              coffeeName,
              notes: coffeeNotes,
              visible: visibleInput.checked,
            };
          }

          return {
            ...content,
            title,
            body,
            visible: visibleInput.checked,
            image: nextImagePath ?? content.image,
          };
        });

        await saveContents(nextContents);

        saveStatus.textContent = "Saved to GitHub";
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Save failed";
      }
    });
        deleteButton?.addEventListener("click", async () => {
      if (
        !contentId ||
        !categorySlug ||
        !saveStatus
      ) {
        return;
      }

      const confirmed = window.confirm(
        "Delete this content? This cannot be undone."
      );

      if (!confirmed) {
        return;
      }

      saveStatus.textContent = "Deleting...";

      try {
        const currentContents = await loadContents();

        const nextContents = currentContents.filter(
          (content) => content.id !== contentId
        );

        await saveContents(nextContents);

        saveStatus.textContent = "Deleted";

        window.location.href =
          `/admin/${categorySlug}`;
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Delete failed";
      }
    });
  </script>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
  color:#111;
}

header{
  margin-bottom:56px;
}

header a{
  display:inline-block;
  margin-bottom:24px;
  color:#777;
  text-decoration:none;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.editor{
  display:flex;
  flex-direction:column;
  gap:32px;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.checkbox-field{
  flex-direction:row;
  align-items:center;
  gap:10px;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

.checkbox-field label{
  color:#111;
  letter-spacing:.08em;
}

input,
textarea{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
  line-height:1.8;
}

input[type="checkbox"]{
  width:auto;
}

input[type="file"]{
  border:none;
  padding:0;
  font-size:12px;
}

textarea{
  resize:vertical;
}

.note{
  margin:0;
  color:#999;
  font-size:11px;
  line-height:1.6;
}

img{
  display:block;
  width:min(100%,420px);
  height:auto;
}

img.is-hidden{
  display:none;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
  flex-wrap:wrap;
}

.save-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

.delete-button{
  border:none;
  background:transparent;
  color:#999;
  padding:12px 0;
  cursor:pointer;
  font-size:12px;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>    