---
import LogoButton from "./LogoButton.astro";
import MenuButton from "./MenuButton.astro";
import MenuPanel from "./MenuPanel.astro";
---

<LogoButton />
<MenuButton />
<MenuPanel />

<script>
  const menuButton = document.querySelector(".menu-button");
  const menuPanel = document.querySelector(".menu-panel");

  menuButton?.addEventListener("click", () => {
    menuButton.classList.toggle("is-open");
    menuPanel?.classList.toggle("is-open");
  });

  function updateScrolledState(scrollTop) {
    document.body.classList.toggle("has-scrolled", scrollTop > 20);
  }

  const scrollRoot = document.querySelector("[data-scroll-root]");

  if (scrollRoot) {
    updateScrolledState(scrollRoot.scrollTop);

    scrollRoot.addEventListener("scroll", () => {
      updateScrolledState(scrollRoot.scrollTop);
    });
  } else {
    updateScrolledState(window.scrollY);

    window.addEventListener("scroll", () => {
      updateScrolledState(window.scrollY);
    });
  }
</script>