---
import Layout from "../../../layouts/Layout.astro";
import { CATEGORIES } from "../../../config/site";
import { CONTENTS } from "../../../data/contents";

export function getStaticPaths() {
  return CONTENTS.map((content) => {
    const category = CATEGORIES.find(
      (category) => category.id === content.categoryId
    );

    return {
      params: {
        category: category?.slug,
        content: content.id,
      },
      props: {
        content,
        category,
      },
    };
  });
}

const { content, category } = Astro.props;
---

<Layout title={`${content.title} | Musée de l'Instant CMS`} showHeader={false}>
  <main class="admin">
    <header>
      <a href={`/admin/${category.slug}`}>← {category.title}</a>
      <h1>Edit Content</h1>
    </header>

    <section class="editor" data-content-id={content.id} data-category-slug={category.slug}>
      <div class="field">
        <label for="title">Title</label>
        <input id="title" type="text" value={content.title} />
      </div>

      <div class="field">
        <label for="body">Body</label>
        <textarea id="body" rows="8">{content.body}</textarea>
      </div>

      <div class="field">
        <label>Image</label>
        {content.image && <img src={content.image} alt={content.title} />}
        <p class="note">Image upload will be added later.</p>
      </div>

      <div class="field checkbox-field">
        <input id="visible" type="checkbox" checked={content.visible} />
        <label for="visible">Visible</label>
      </div>

      <div class="actions">
        <button type="button" id="save-button" class="save-button">Save</button>
        <button type="button" id="delete-button" class="delete-button">Delete Content</button>
        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script>
    const API_URL = "https://musee-cms-api.azamisound.workers.dev";

    const editor = document.querySelector(".editor");
    const contentId = editor?.getAttribute("data-content-id");
    const categorySlug = editor?.getAttribute("data-category-slug");

    const titleInput = document.querySelector("#title");
    const bodyInput = document.querySelector("#body");
    const visibleInput = document.querySelector("#visible");
    const saveButton = document.querySelector("#save-button");
    const deleteButton = document.querySelector("#delete-button");
    const saveStatus = document.querySelector("#save-status");

    async function loadContents() {
      const currentRes = await fetch(`${API_URL}/contents`);
      const currentData = await currentRes.json();

      if (!currentData.ok) {
        throw new Error("Could not load contents.");
      }

      return currentData.contents;
    }

    async function saveContents(contents) {
      const saveRes = await fetch(`${API_URL}/contents`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          contents,
        }),
      });

      const saveData = await saveRes.json();

      if (!saveData.ok) {
        throw new Error("Could not save contents.");
      }

      return saveData;
    }

    saveButton?.addEventListener("click", async () => {
      if (!contentId || !titleInput || !bodyInput || !visibleInput || !saveStatus) return;

      saveStatus.textContent = "Saving...";

      try {
        const currentContents = await loadContents();

        const nextContents = currentContents.map((content) => {
          if (content.id !== contentId) return content;

          return {
            ...content,
            title: titleInput.value,
            body: bodyInput.value,
            visible: visibleInput.checked,
          };
        });

        await saveContents(nextContents);

        saveStatus.textContent = visibleInput.checked
          ? "Saved to GitHub"
          : "Saved as hidden";
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Save failed";
      }
    });

    deleteButton?.addEventListener("click", async () => {
      if (!contentId || !categorySlug || !saveStatus) return;

      const confirmed = window.confirm(
        "Delete this content? This cannot be undone."
      );

      if (!confirmed) return;

      saveStatus.textContent = "Deleting...";

      try {
        const currentContents = await loadContents();

        const nextContents = currentContents.filter(
          (content) => content.id !== contentId
        );

        await saveContents(nextContents);

        saveStatus.textContent = "Deleted";

        window.location.href = `/admin/${categorySlug}`;
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Delete failed";
      }
    });
  </script>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
  color:#111;
}

header{
  margin-bottom:56px;
}

header a{
  display:inline-block;
  margin-bottom:24px;
  color:#777;
  text-decoration:none;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.editor{
  display:flex;
  flex-direction:column;
  gap:32px;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.checkbox-field{
  flex-direction:row;
  align-items:center;
  gap:10px;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

.checkbox-field label{
  color:#111;
  letter-spacing:.08em;
}

input,
textarea{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
  line-height:1.8;
}

input[type="checkbox"]{
  width:auto;
}

textarea{
  resize:vertical;
}

img{
  display:block;
  width:min(100%,420px);
  height:auto;
}

.note{
  margin:0;
  font-size:11px;
  color:#999;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
  flex-wrap:wrap;
}

.save-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

.delete-button{
  border:none;
  background:transparent;
  color:#999;
  padding:12px 0;
  cursor:pointer;
  font-size:12px;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>