---
import Layout from "../../../layouts/Layout.astro";
import { CATEGORIES } from "../../../config/site";

export function getStaticPaths() {
  return CATEGORIES
    .filter(category => category.visible)
    .map(category => ({
      params: {
        category: category.slug,
      },
      props: {
        category,
      },
    }));
}

const { category } = Astro.props;
---

<Layout title="New Content | Musée de l'Instant CMS" showHeader={false}>
  <main class="admin">
    <header>
      <a href={`/admin/${category.slug}`}>← {category.title}</a>
      <h1>New Content</h1>
    </header>

    <section class="editor" data-category-id={category.id} data-category-slug={category.slug}>
      <div class="field">
        <label for="title">Title</label>
        <input id="title" type="text" />
      </div>

      <div class="field">
        <label for="body">Body</label>
        <textarea id="body" rows="8"></textarea>
      </div>

      <div class="actions">
        <button type="button" id="save-button" class="save-button">Save</button>
        <p id="save-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script>
    const API_URL = "https://musee-cms-api.azamisound.workers.dev";

    const editor = document.querySelector(".editor");
    const categoryId = editor?.getAttribute("data-category-id");
    const categorySlug = editor?.getAttribute("data-category-slug");

    const titleInput = document.querySelector("#title");
    const bodyInput = document.querySelector("#body");
    const saveButton = document.querySelector("#save-button");
    const saveStatus = document.querySelector("#save-status");

    function getNextContentId(contents) {
      const maxNumber = contents.reduce((max, content) => {
        const match = content.id?.match(/^content(\d+)$/);
        if (!match) return max;

        const number = Number(match[1]);
        return Number.isFinite(number) ? Math.max(max, number) : max;
      }, 0);

      return `content${String(maxNumber + 1).padStart(6, "0")}`;
    }

    saveButton?.addEventListener("click", async () => {
      if (!categoryId || !categorySlug || !titleInput || !bodyInput || !saveStatus) return;

      saveStatus.textContent = "Saving...";

      try {
        const currentRes = await fetch(`${API_URL}/contents`);
        const currentData = await currentRes.json();

        if (!currentData.ok) {
          throw new Error("Could not load contents.");
        }

        const nextId = getNextContentId(currentData.contents);

        const sameCategoryContents = currentData.contents.filter(
          (content) => content.categoryId === categoryId
        );

        const nextOrder = sameCategoryContents.length + 1;

        const newContent = {
          id: nextId,
          categoryId,
          slug: nextId,
          image: "",
          title: titleInput.value,
          body: bodyInput.value,
          visible: true,
          order: nextOrder,
        };

        const nextContents = [...currentData.contents, newContent];

        const saveRes = await fetch(`${API_URL}/contents`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            contents: nextContents,
          }),
        });

        const saveData = await saveRes.json();

        if (!saveData.ok) {
          throw new Error("Could not save contents.");
        }

        saveStatus.textContent = "Saved to GitHub";

        window.location.href = `/admin/${categorySlug}/${nextId}`;
      } catch (error) {
        console.error(error);
        saveStatus.textContent = "Save failed";
      }
    });
  </script>
</Layout>

<style>
.admin{
  max-width:720px;
  margin:120px auto;
  padding:24px;
  font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
  color:#111;
}

header{
  margin-bottom:56px;
}

header a{
  display:inline-block;
  margin-bottom:24px;
  color:#777;
  text-decoration:none;
  font-size:12px;
}

h1{
  margin:0;
  font-size:24px;
  font-weight:400;
}

.editor{
  display:flex;
  flex-direction:column;
  gap:32px;
}

.field{
  display:flex;
  flex-direction:column;
  gap:10px;
}

label{
  font-size:11px;
  letter-spacing:.12em;
  color:#777;
}

input,
textarea{
  width:100%;
  border:1px solid #ddd;
  background:#fff;
  color:#111;
  padding:12px;
  font:inherit;
  font-size:14px;
  line-height:1.8;
}

textarea{
  resize:vertical;
}

.actions{
  display:flex;
  align-items:center;
  gap:16px;
}

.save-button{
  border:none;
  background:#111;
  color:#fff;
  padding:12px 18px;
  cursor:pointer;
  font-size:12px;
}

#save-status{
  margin:0;
  font-size:12px;
  color:#777;
}
</style>