---
const {
  horizontal = false,
} = Astro.props;
---

<div class:list={["edge-fade", horizontal && "has-horizontal"]} aria-hidden="true">
  <span class="edge-fade-top"></span>
  <span class="edge-fade-bottom"></span>
  <span class="edge-fade-left"></span>
  <span class="edge-fade-right"></span>
</div>

<style>
.edge-fade{
  --edge-fade-size-top:80px;
  --edge-fade-size-bottom:30px;
  --edge-fade-size-x:32px;

  pointer-events:none;
  z-index:900;
}

.edge-fade span{
  position:fixed;
  pointer-events:none;
  z-index:900;
}

.edge-fade-top{
  top:0;
  left:0;
  right:0;
  height:calc(
    env(safe-area-inset-top, 0px)
    + var(--edge-fade-size-top)
  );
  background:linear-gradient(
    to bottom,
    #fff 0,
    #fff env(safe-area-inset-top, 0px),
    rgba(255,255,255,.98)
      calc(env(safe-area-inset-top, 0px) + 12px),
    rgba(255,255,255,.88)
      calc(env(safe-area-inset-top, 0px) + 28px),
    rgba(255,255,255,.55)
      calc(env(safe-area-inset-top, 0px) + 58px),
    rgba(255,255,255,0)
      calc(
        env(safe-area-inset-top, 0px)
        + var(--edge-fade-size-top)
      )
  );
}

.edge-fade-bottom{
  bottom:0;
  left:0;
  right:0;
  height:calc(
    env(safe-area-inset-bottom, 0px)
    + var(--edge-fade-size-bottom)
  );
  background:linear-gradient(
    to top,
    #fff 0,
    #fff env(safe-area-inset-bottom, 0px),
    rgba(255,255,255,.96)
      calc(env(safe-area-inset-bottom, 0px) + 8px),
    rgba(255,255,255,.78)
      calc(env(safe-area-inset-bottom, 0px) + 18px),
    rgba(255,255,255,.38)
      calc(env(safe-area-inset-bottom, 0px) + 34px),
    rgba(255,255,255,0)
      calc(
        env(safe-area-inset-bottom, 0px)
        + var(--edge-fade-size-bottom)
      )
  );
}

.edge-fade-left,
.edge-fade-right{
  display:none;
}

.edge-fade.has-horizontal .edge-fade-left{
  display:block;
  top:0;
  bottom:0;
  left:0;
  width:var(--edge-fade-size-x);
  background:linear-gradient(
    to right,
    #fff 0%,
    rgba(255,255,255,.98) 12%,
    rgba(255,255,255,.88) 28%,
    rgba(255,255,255,.55) 58%,
    rgba(255,255,255,0) 100%
  );
}

.edge-fade.has-horizontal .edge-fade-right{
  display:block;
  top:0;
  bottom:0;
  right:0;
  width:var(--edge-fade-size-x);
  background:linear-gradient(
    to left,
    #fff 0%,
    rgba(255,255,255,.98) 12%,
    rgba(255,255,255,.88) 28%,
    rgba(255,255,255,.55) 58%,
    rgba(255,255,255,0) 100%
  );
}
</style>