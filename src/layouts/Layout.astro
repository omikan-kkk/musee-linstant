---
import Header from "../components/header/Header.astro";
import EdgeFade from "../components/common/EdgeFade.astro";

const {
  title = "Musée de l'Instant",
  showHeader = false,
  showEdgeFade = false,
  edgeFadeHorizontal = false,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>{title}</title>
  </head>

  <body class:list={[showHeader && "has-scrolled", showEdgeFade && "has-edge-fade"]}>
    {showEdgeFade ? (
      <div class="fade-viewport">
        <div class="fade-scroll" data-scroll-root>
          <slot />
        </div>

        <EdgeFade horizontal={edgeFadeHorizontal} />
      </div>
    ) : (
      <slot />
    )}

    <Header />
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #fff;
    color: #111;
    font-family: serif;
  }

  :global(body.has-edge-fade) {
    height: 100dvh;
    overflow: hidden;
  }

  :global(*) {
    box-sizing: border-box;
  }

  .fade-viewport {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: #fff;
    z-index: 0;
  }

  .fade-scroll {
    width: 100%;
    height: 100dvh;
    overflow-x: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: none;
  }
</style>