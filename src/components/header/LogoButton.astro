---
import Logo from "./Logo.astro";
---

<a class="site-logo" href="/" aria-label="Back to top">
  <Logo />
</a>

<style>
  .site-logo {
    position: fixed;
    top: 28px;
    left: 32px;
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    text-decoration: none;
    transition: opacity 900ms ease;
  }

  :global(body.has-scrolled) .site-logo {
    opacity: 1;
    pointer-events: auto;
  }
</style>