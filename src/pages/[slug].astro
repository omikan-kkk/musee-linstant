---
import Layout from "../layouts/Layout.astro";
import GalleryGrid from "../components/gallery/GalleryGrid.astro";
import GalleryItem from "../components/gallery/GalleryItem.astro";
import { CATEGORIES } from "../config/site";
import { CONTENTS } from "../data/contents";

export function getStaticPaths() {
  return CATEGORIES
    .filter((category) => category.visible)
    .map((category) => ({
      params: { slug: category.slug },
      props: { category },
    }));
}

const { category } = Astro.props;

const items = CONTENTS.filter(
  (item) => item.categoryId === category.id
);
---

<Layout title={`${category.title} | Musée de l'Instant`} showHeader={true}>
  <GalleryGrid items={items}>
    {items.map((item) => (
      <GalleryItem
        image={item.image}
        title={item.title}
        body={item.body}
        href={`/${category.slug}/${item.slug}`}
      />
    ))}
  </GalleryGrid>
</Layout>