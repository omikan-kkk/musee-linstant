---
import Header from "../components/header/Header.astro";
import { THEME } from "../config/theme";

const {
  title = "Musée de l'Instant",
  showHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />

    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Noto+Serif+JP:wght@200;300;400&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body
    class:list={[showHeader && "has-scrolled"]}
    style={`font-family:${THEME.typography.fontFamily};`}
  >
    <Header />
    <slot />
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #fff;
    color: #111;
  }

  :global(*) {
    box-sizing: border-box;
  }
</style>