---
import { CATEGORIES } from "../../config/site";

const visibleCategories = CATEGORIES
  .filter((category) => category.visible)
  .sort((a, b) => a.order - b.order);
---

<nav class="menu-panel" aria-hidden="true">
  <ul>
    {visibleCategories.map((category) => (
      <li><a href={`/${category.slug}`}>{category.title}</a></li>
    ))}
  </ul>
</nav>

<style>
  .menu-panel {
    position: fixed;
    inset: 0;
    z-index: 10;
    display: grid;
    place-items: center;
    background: #fff;
    opacity: 0;
    pointer-events: none;
    transition: opacity 700ms ease;
  }

  .menu-panel.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .menu-panel ul {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: center;
  }

  .menu-panel li + li {
    margin-top: 22px;
  }

  .menu-panel a {
    text-decoration: none;
    color: #111;
    font-size: 18px;
    letter-spacing: 0.12em;
  }
</style>