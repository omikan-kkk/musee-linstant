---
import Header from "../components/header/Header.astro";
import EdgeFade from "../components/common/EdgeFade.astro";
import { THEME } from "../config/site";

const {
  title = "Musée de l'Instant",
  showHeader = false,
  showEdgeFade = false,
  edgeFadeHorizontal = false,
  lockVerticalScroll = false,
} = Astro.props;

const latinFontFamilies = {
  helvetica: '"Helvetica Neue", Helvetica, Arial',
  "system-sans": '-apple-system, BlinkMacSystemFont, "Segoe UI"',
  georgia: 'Georgia, "Times New Roman"',
  times: '"Times New Roman", Times',
  "system-serif": 'ui-serif, Georgia, "Times New Roman"',
};

const japaneseFontFamilies = {
  sans: '"Hiragino Kaku Gothic ProN", "Yu Gothic", "YuGothic", Meiryo, sans-serif',
  "yu-gothic": '"Yu Gothic", "YuGothic", "Hiragino Kaku Gothic ProN", Meiryo, sans-serif',
  "hiragino-sans": '"Hiragino Sans", "Hiragino Kaku Gothic ProN", "Yu Gothic", sans-serif',
  serif: '"Hiragino Mincho ProN", "Yu Mincho", "YuMincho", serif',
  "yu-mincho": '"Yu Mincho", "YuMincho", "Hiragino Mincho ProN", serif',
  "hiragino-mincho": '"Hiragino Mincho ProN", "Yu Mincho", "YuMincho", serif',
};

const latinFontFamily =
  latinFontFamilies[THEME.fontFamilyLatin] ??
  latinFontFamilies.helvetica;

const japaneseFontFamily =
  japaneseFontFamilies[THEME.fontFamilyJapanese] ??
  japaneseFontFamilies.sans;

const siteFontFamily = `${latinFontFamily}, ${japaneseFontFamily}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>{title}</title>
  </head>

  <body
    class:list={[
      showHeader && "has-scrolled",
      showHeader && "force-header",
      showEdgeFade && "has-edge-fade",
    ]}
    style={`
      --site-font-family:${siteFontFamily};

      --navigation-size:${THEME.fontSizes.navigation}px;
      --gallery-list-title-size:${THEME.fontSizes.galleryListTitle}px;
      --gallery-list-caption-size:${THEME.fontSizes.galleryListCaption}px;
      --gallery-detail-title-size:${THEME.fontSizes.galleryDetailTitle}px;
      --gallery-detail-caption-size:${THEME.fontSizes.galleryDetailCaption}px;
      --book-list-size:${THEME.fontSizes.bookList}px;
      --coffee-list-size:${THEME.fontSizes.coffeeList}px;

      --navigation-color:${THEME.colors.navigation};
      --gallery-list-title-color:${THEME.colors.galleryListTitle};
      --gallery-list-caption-color:${THEME.colors.galleryListCaption};
      --gallery-detail-title-color:${THEME.colors.galleryDetailTitle};
      --gallery-detail-caption-color:${THEME.colors.galleryDetailCaption};
      --book-list-color:${THEME.colors.bookList};
      --coffee-list-color:${THEME.colors.coffeeList};
    `}
  >
    {showEdgeFade ? (
      <div class="fade-viewport">
        <div
          class:list={["fade-scroll", lockVerticalScroll && "is-y-locked"]}
          data-scroll-root
        >
          <slot />
        </div>

        <EdgeFade horizontal={edgeFadeHorizontal} />
      </div>
    ) : (
      <slot />
    )}

    <Header />
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    background: #fff;
    color: #111;
    font-family: var(--site-font-family);
  }

  :global(body.has-edge-fade) {
    height: 100dvh;
    overflow: hidden;
  }

  :global(*) {
    box-sizing: border-box;
  }

  .fade-viewport {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: #fff;
    z-index: 0;
  }

  .fade-scroll {
    width: 100%;
    height: 100dvh;
    overflow-x: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: none;
  }

  .fade-scroll.is-y-locked {
    overflow-y: hidden;
  }
</style>